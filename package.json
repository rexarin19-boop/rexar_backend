{
  "name": "rexar-backend",
  "version": "1.0.0",
  "description": "Rexar API — Express + Firebase Phone Auth + Prisma",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "npm run db:generate && node --watch src/server.js",
    "postinstall": "prisma generate",
    "start": "node src/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:test": "node scripts/test-db.mjs",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "firebase-admin": "^13.6.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "prisma": "^6.19.0"
  },
  "engines": {
    "node": ">=18"
  },
  "private": true
}
