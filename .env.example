# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=*

# firebase | jwt
AUTH_MODE=firebase

# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Only when AUTH_MODE=jwt
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
