generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLAYER
  ORGANIZER
  MODERATOR
  FINANCE_ADMIN
  SUPER_ADMIN
}

model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  firebaseUid String   @unique @map("firebase_uid")
  phone       String   @unique
  displayName String?  @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  role        UserRole @default(PLAYER)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  tournaments   Tournament[] @relation("TournamentCreator")

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @map("user_id") @db.ObjectId
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Tournament {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  createdById           String   @map("created_by_id") @db.ObjectId
  tournamentName        String   @map("tournament_name")
  game                  String
  format                String
  date                  String
  time                  String
  isPublic              Boolean  @default(true) @map("is_public")
  entryFee              Float?   @map("entry_fee")
  prizePool             Float    @map("prize_pool")
  maxParticipants       Int      @map("max_participants")
  rules                 String?
  registrationDeadline  String   @map("registration_deadline")
  allowTeamRegistration Boolean  @default(false) @map("allow_team_registration")
  autoApprovePlayers    Boolean  @default(true) @map("auto_approve_players")
  matches               Int
  roomSize              Int      @map("room_size")
  map                   String
  spectatorMode         Boolean  @default(true) @map("spectator_mode")
  prizeFirst            Float    @map("prize_first")
  prizeSecond           Float    @map("prize_second")
  prizeThird            Float    @map("prize_third")
  bannerUri             String?  @map("banner_uri")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  createdBy User @relation("TournamentCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@map("tournaments")
}
